{
  "name": "morpheus-gpt-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate --schema ./prisma/schema.dev.prisma && ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate --schema ./prisma/schema.prisma && tsc",
    "start": "node dist/index.js",
    "test": "prisma generate --schema ./prisma/schema.dev.prisma && vitest run",
    "db:push": "prisma db push --schema ./prisma/schema.dev.prisma",
    "db:push:prod": "node -e \"require('dotenv').config(); process.env.DATABASE_URL=process.env.DATABASE_URL_PROD; require('child_process').execSync('prisma db push --schema ./prisma/schema.prisma', {stdio:'inherit', env:process.env})\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^6.3.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.3.0",
    "splunk-logging-hec": "^0.10.2",
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "vitest": "^3.0.0"
  }
}
