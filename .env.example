# Server (local dev uses SQLite, production uses PostgreSQL)
# Local: DATABASE_URL="file:./prisma/dev.db"
# Prod:  DATABASE_URL="postgresql://user:password@host:5432/dbname"
DATABASE_URL="file:./prisma/dev.db"
ANTHROPIC_API_KEY="sk-ant-..."
JWT_SECRET="change-me-to-a-random-secret"
PORT=3001

# Client (set in client/.env or as Vercel env var)
VITE_API_URL="http://localhost:3001"
